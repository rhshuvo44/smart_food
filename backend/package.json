{
  "name": "@smartfood/backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx dev-start.ts",
    "dev:mem": "tsx dev-start.ts",
    "dev:tsnd": "ts-node-dev --respawn --transpile-only src/server.ts",
