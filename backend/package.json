    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.7",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "http-status": "^1.8.1",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.2.0",
    "morgan": "^1.11.0",
    "pino": "^8.19.0",
