# Server Configuration
PORT=5000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/smart_food

# JWT
JWT_ACCESS_SECRET=your-jwt-access-secret-key-min-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-min-32-chars

# CORS
CORS_ORIGIN=http://localhost:8081

# Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# SSLCommerz (for BDT payments)
SSLCOMMERZ_STORE_ID=testbox
SSLCOMMERZ_STORE_PASSWORD=testbox123
SSLCOMMERZ_BASE_URL=https://sandbox.sslcommerz.com

# Payment gateway selection (stripe | sslcommerz | both)
PAYMENT_GATEWAY=both

# Maps & Location
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token
DEFAULT_SEARCH_RADIUS_KM=10
DRIVER_AVERAGE_SPEED_KMH=30
DELIVERY_BASE_FEE=5.00
DELIVERY_FEE_PER_KM=1.50
