{
  "expo": {
    "name": "SmartFood Customer",
    "slug": "smartfood-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "smartfood",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "your-expo-project-id"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartfood.customer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SmartFood uses your location to find nearby restaurants and track delivery status.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SmartFood needs background location access for live delivery tracking."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF6B35"
      },
      "package": "com.smartfood.customer",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-updates",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SmartFood needs background location access for live delivery tracking.",
          "locationWhenInUsePermission": "SmartFood uses your location to find nearby restaurants and track delivery status."
        }
      ],
      [
        "react-native-maps",
        {
          "provider": "google"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false,
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0"
          },
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ]
    ]
  }
}
