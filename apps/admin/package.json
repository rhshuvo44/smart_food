{
  "name": "@smartfood/admin-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit",
    "eas-build:development": "eas build --platform android --profile development",
    "eas-build:preview": "eas build --platform android --profile preview",
    "eas-build:production:android": "eas build --platform android --profile production",
    "eas-build:production:ios": "eas build --platform ios --profile production",
    "eas-submit:android": "eas submit --platform android --profile production",
    "eas-submit:ios": "eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@smartfood/shared": "*",
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.7.0",
    "date-fns": "^3.6.0",
    "expo": "~52.0.0",
    "expo-build-properties": "~0.13.3",
    "expo-location": "~18.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~57.0.1",
    "expo-status-bar": "~2.0.0",
    "expo-updates": "~0.27.5",
    "nativewind": "^4.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-maps": "1.18.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "^0.11.0",
    "socket.io-client": "^4.7.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.0",
    "eas-cli": "^3.0.0",
    "typescript": "^5.4.0"
  }
}
